from flask import Flask, request
import torch
import cv2
import numpy as np
import base64

app = Flask(__name__)

# Load your trained model
model = torch.hub.load(
    'ultralytics/yolov5', 
    'custom', 
    path=r'C:/Users/Elijah/YoloRepo/yolov5/runs/train/my_yolov5s_model_finetune/weights/best.pt'
)

latest_image = None

@app.route('/upload', methods=['POST'])
def upload():
    global latest_image

    img_bytes = request.data
    nparr = np.frombuffer(img_bytes, np.uint8)
    img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)

    results = model(img)
    results.render()

    latest_image = results.ims[0]

    print(results.pandas().xyxy[0])

    return "OK"

@app.route('/')
def index():
    global latest_image

    if latest_image is None:
        return "Waiting for image..."

    _, buffer = cv2.imencode('.jpg', latest_image)
    img_base64 = base64.b64encode(buffer).decode('utf-8')

    return f"""
    <h2>YOLOv5 Detection Result</h2>
    <img src="data:image/jpeg;base64,{img_base64}" width="600"/>
    """

if __name__ == '__main__':
    app.run(host='192.168.100.86', port=5000)
